# Vypexrock Backend Environment Variables

# Environment
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vypexrock
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# API
API_V1_PREFIX=/api/v1
PUBLIC_API_BASE_URL=http://localhost:8000

# Frontend URL (for OAuth redirects and email links)
FRONTEND_URL=http://localhost:3000

# SMTP Configuration (Required for email verification)
# Gmail Example:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=security@vypexrock.com
SMTP_FROM_NAME=Vypexrock Security
SMTP_USE_TLS=true

# SendGrid Example:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=your-sendgrid-api-key

# AWS SES Example:
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USERNAME=your-ses-smtp-username
# SMTP_PASSWORD=your-ses-smtp-password

# OAuth - Google
# Get credentials from: https://console.cloud.google.com/
# IMPORTANT: Add these to your .env file (not committed to git)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# OAuth - GitHub
# Get credentials from: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

# OAuth - Apple (Optional)
# Get credentials from: https://developer.apple.com/
APPLE_CLIENT_ID=com.vypexrock.service
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
APPLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/apple/callback

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=10
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=30

# Token Expiration (in minutes)
EMAIL_VERIFICATION_EXPIRE_MINUTES=60
PASSWORD_RESET_EXPIRE_MINUTES=15
PHONE_VERIFICATION_EXPIRE_MINUTES=10

# Binance API
BINANCE_REST_URL=https://api.binance.com
BINANCE_WS_URL=wss://stream.binance.com:9443/stream

# CoinGecko API
COINGECKO_URL=https://api.coingecko.com/api/v3

# Telegram Bot (Optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
TELEGRAM_SIGNAL_ENABLED=true

# AI Provider (Optional)
AI_PROVIDER=auto
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4
NVIDIA_API_KEY=your-nvidia-api-key

# Plans
FREE_PLAN_CODE=free
PREMIUM_PLAN_CODE=pro

# File Upload
CHART_MEDIA_DIR=media/charts
AVATAR_UPLOAD_DIR=media/avatars
